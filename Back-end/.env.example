PORT=5000
NODE_ENV=development

# MongoDB connection string. Use a local MongoDB instance or a free MongoDB Atlas cluster.
MONGO_URI=mongodb://127.0.0.1:27017/pawlink

# JWT secret used to sign auth tokens. Change this to a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# URL of the frontend app, used for CORS
CLIENT_URL=http://localhost:3000
